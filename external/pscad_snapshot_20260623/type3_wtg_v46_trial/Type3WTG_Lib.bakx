        <line x1="-46" y1="7" x2="-40" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="0.4" port="" />
      </svg>
      <script>
        <segment name="Fortran" id="482129785" classid="CoreSegment"><![CDATA[      IF (($Vt.GT.$V_up).OR.($Vt.LT.$V_dip))THEN
            $Vdip = 1
      ELSE
            $Vdip = 0
      ENDIF]]></segment>
        <segment name="Branch" id="2018627983" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Computations" id="733375723" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
