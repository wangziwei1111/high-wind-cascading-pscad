    <Definition classid="UserCmpDefn" name="V_dip_sig" group="" url="" version="" build="" crc="115990954" view="false" date="0" id="1756885805">
      <paramlist>
        <param name="Description" value="" />
      </paramlist>
      <form name="" w="320" h="400" splitter="60">
        <category name="Voltage limits" visible="true">
          <cond />
          <parameter desc="Low voltage condition trigger voltage (pu)" name="V_dip" group="" unit="pu" min="0.0" max="+1e+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[0.9]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="High voltage condition trigger voltage (pu)" name="V_up" group="General" unit="pu" min="0" max="2" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[1.1]]></value>
            <cond />
            <help />
          </parameter>
        </category>
      </form>
      <svg viewBox="-200 -200 200 200" size="4">
        <port model="Transfer" name="Vdip" x="54" y="0" dim="1" mode="Output" type="Real" internal="false"><![CDATA[true]]></port>
        <port model="Transfer" name="Vt" x="-54" y="0" dim="1" mode="Input" type="Real" internal="false"><![CDATA[true]]></port>
        <cond><![CDATA[true]]></cond>
        <rect x="-39" y="-19" width="78" height="37" stroke="Black" stroke-dasharray="none" stroke-width="0.2" fill-style="Hollow" fill-fg="Black" fill-bg="" port="" />
        <line x1="54" y1="0" x2="38" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="Fex" />
        <text x="21" y="1" stroke="Black" fill="Black" font-size="Small" text-anchor="Middle"><![CDATA[Vdip]]></text>
