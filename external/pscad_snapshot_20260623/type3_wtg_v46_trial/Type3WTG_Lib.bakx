      <script>
        <segment name="Fortran" id="1350712455" classid="CoreSegment"><![CDATA[#STORAGE REAL:9

STORF(NSTORF) = 0
STORF(NSTORF+1) = $lambda
STORF(NSTORF+2) = $lambda*STORF(NSTORF+1)
STORF(NSTORF+3) = $lambda*STORF(NSTORF+2)
STORF(NSTORF+4) = $lambda*STORF(NSTORF+3)

STORF(NSTORF+5) = $theta
STORF(NSTORF+6) = $theta*STORF(NSTORF+5)
STORF(NSTORF+7) = $theta*STORF(NSTORF+6)
STORF(NSTORF+8) = $theta*STORF(NSTORF+7)

STORF(NSTORF)= $Data1+$Data2*STORF(NSTORF+1)+$Data3*STORF(NSTORF+2)+$Data4*STORF(NSTORF+3)+$Data5*STORF(NSTORF+4)

STORF(NSTORF)= STORF(NSTORF)+($Data6+$Data7*STORF(NSTORF+1)+$Data8*STORF(NSTORF+2)+$Data9*STORF(NSTORF+3)+$Data10*STORF(NSTORF+4))*STORF(NSTORF+5)

STORF(NSTORF)= STORF(NSTORF)+($Data11+$Data12*STORF(NSTORF+1)+$Data13*STORF(NSTORF+2)+$Data14*STORF(NSTORF+3)+$Data15*STORF(NSTORF+4))*STORF(NSTORF+6)

STORF(NSTORF)= STORF(NSTORF)+($Data16+$Data17*STORF(NSTORF+1)+$Data18*STORF(NSTORF+2)+$Data19*STORF(NSTORF+3)+$Data20*STORF(NSTORF+4))*STORF(NSTORF+7)

STORF(NSTORF)= STORF(NSTORF)+($Data21+$Data22*STORF(NSTORF+1)+$Data23*STORF(NSTORF+2)+$Data24*STORF(NSTORF+3)+$Data25*STORF(NSTORF+4))*STORF(NSTORF+8)

if (STORF(NSTORF) .LE. -0.05) then
	$CP = -0.05
else
	$CP = STORF(NSTORF)
endif

NSTORF = NSTORF+9]]></segment>
