      <form name="" w="400" h="500" splitter="70">
        <category name="Configuration" visible="true">
          <cond />
          <parameter desc="Turbine radius" name="Rad_turb" group="2. Turbine parameters" unit="m" min="1" max="+1e+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[63 [m]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Reference machine speed set point" name="Wref_sp" group="1. Machine parameters" unit="pu" min="0.0" max="+1e+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[1.2 [pu]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Turbine RPM at machine nom speed" name="VRot_nom" group="2. Turbine parameters" unit="rpm" min="1" max="+1e+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[12 [rpm]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Air density kg/m3" name="rho" group="2. Turbine parameters" unit="" min="0.0" max="+1e+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[1.225]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Base Active power" name="Pbase" group="1. Machine parameters" unit="MW" min="0.0" max="+1e+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[5.0 [MW]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Cut-in wind speed" name="vWcutin" group="2. Turbine parameters" unit="m/s" min="-1e+308" max="+1e+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[3.0]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Cut-out wind speed" name="vWcutout" group="2. Turbine parameters" unit="m/s" min="-1e+308" max="+1e+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[25.0]]></value>
            <cond />
            <help />
          </parameter>
        </category>
